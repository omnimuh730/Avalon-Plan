# NextOffer — local development defaults (copy to Athens-server/.env, connector/.env, etc.)

# ── Infrastructure (started by `npm start` via Docker) ──
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=AthensDB
REDIS_URL=redis://127.0.0.1:6379

# ── Service URLs ──
PORT=7979
UNIFIED_AI_URL=http://127.0.0.1:8790
CONNECTOR_URL=http://127.0.0.1:8781
ATHENS_SERVER_URL=http://127.0.0.1:7979

# Athens frontend (Athens/.env)
VITE_API_BASE=http://127.0.0.1:7979/api
VITE_CONNECTOR_URL=http://127.0.0.1:8781

# ── Agent defaults ──
AGENT_DEFAULT_MODE=plan
AI_MAX_TOKENS_PER_RUN=500000

# ── API keys (required for LLM features) ──
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# ── Optional: similar-jobs embeddings (not required for Best Match %) ──
# QDRANT_URL=http://127.0.0.1:6333
# OLLAMA_URL=http://127.0.0.1:11434
# EMBEDDING_PROVIDER=ollama
