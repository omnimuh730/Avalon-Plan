# lancer-backend (copy to `.env` in this folder)
PORT=7979
# Listen on all interfaces so LAN clients (e.g. http://192.168.x.x:7979/api) can reach Node.
# Use HOST=127.0.0.1 if you only want local access.
HOST=0.0.0.0

# MongoDB (required) — primary database for reads and most collections
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=AIMS_local

# Cloud MongoDB — account_info writes are mirrored here; Vendor Monitor reads bid_records from cloud.
MONGO_CLOUD_URL=mongodb+srv://user:password@cluster.mongodb.net/

# Socket.IO CORS (comma-separated origins, or * for dev / Chrome extension)
# SOCKET_CORS_ORIGINS=*

# Neo4j skill knowledge graph
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=skillgraph-dev
# Set to true to fail startup when Neo4j is unreachable
# NEO4J_REQUIRED=false

# Skill graph LLM enrichment (OpenAI + DeepSeek)
# Keys can also come from Settings → Profile (autoBidProfile)
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# SKILL_GRAPH_OPENAI_API_KEY=sk-...
# SKILL_GRAPH_DEEPSEEK_API_KEY=sk-...
# SKILL_GRAPH_LLM_PROVIDER=auto
# SKILL_GRAPH_KEYWORD_MODEL=gpt-4o-mini
# SKILL_GRAPH_ENRICH_MODEL=gpt-4o-mini
# SKILL_GRAPH_ENRICH_MODEL_ESCALATED=gpt-4o
# SKILL_GRAPH_DEEPSEEK_KEYWORD_MODEL=deepseek-v4-flash
# SKILL_GRAPH_DEEPSEEK_ENRICH_MODEL=deepseek-v4-flash
# SKILL_GRAPH_DEEPSEEK_ENRICH_ESCALATED=deepseek-v4-pro
# SKILL_GRAPH_ENRICHMENT_ENABLED=true
# SKILL_GRAPH_WORKER_INTERVAL_MS=5000
# SKILL_GRAPH_JOB_ANALYSIS_BATCH_SIZE=2
# SKILL_COOC_THRESHOLD=3
