# Connector — copy to connector/.env

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=AthensDB

# Connector listen port (do NOT use 8979 — that is Athens-server)
PORT=8781

UNIFIED_AI_URL=http://127.0.0.1:8790
ATHENS_SERVER_URL=http://127.0.0.1:8979

AGENT_DEFAULT_MODE=plan
AI_MAX_TOKENS_PER_RUN=500000

# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
