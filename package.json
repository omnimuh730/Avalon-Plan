{
  "name": "nextoffer",
  "private": true,
  "workspaces": [
    "packages/shared",
    "Athens-server",
    "unified-ai-server"
  ],
  "scripts": {
    "prestart": "node scripts/prestart.mjs",
    "start": "node scripts/dev-start.mjs",
    "install:all": "npm install && npm install --prefix Athens && npm run build -w unified-ai-server",
    "backfill-job-skills": "npm run backfill-job-skills -w Athens-server",
    "build:ai": "npm run build -w unified-ai-server",
    "test:shared": "node --test packages/shared/src/pricing.test.mjs",
    "start:athens-server": "npm run start -w Athens-server",
    "start:ai": "npm run start -w unified-ai-server",
    "start:ui": "npm run dev --prefix Athens"
  }
}
