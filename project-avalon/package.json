{
  "name": "project-avalon",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w @avalon/shared",
    "dev:backend": "npm run dev -w @avalon/backend",
    "dev:frontend": "npm run dev -w @avalon/frontend",
    "dev:extension": "npm run dev -w @avalon/extension",
    "dev:ai-bff": "npm run dev -w @avalon/ai-bff",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
