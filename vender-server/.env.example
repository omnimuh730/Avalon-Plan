# vender-server bridge

# Cloud MongoDB (optional) — overrides the embedded built-in connection.
# Leave unset to use the value baked into the built bridge.
#
# Option A — SRV (works when DNS SRV lookups are allowed):
# MONGO_CLOUD_URL=mongodb+srv://user:password%21@sidgroup.7n3pyfv.mongodb.net/
#
# Option B — directConnection (vendor PCs / networks that block SRV or multi-host seed lists):
# Use any one shard host — vender-server auto-finds the writable primary.
# Multi-host seed lists from Atlas are auto-converted at startup.
MONGO_CLOUD_URL=mongodb://user:password%21@ac-iuyb1ae-shard-00-02.7n3pyfv.mongodb.net:27017/?ssl=true&authSource=admin&directConnection=true
MONGO_CLOUD_DB=AthensDB

# Main/local MongoDB — bid_records writes from bid-assistant land here.
# Vendor Monitor reads this same DB by default.
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=AthensDB

# Must match Athens-server — encrypts API keys at rest in account_info.autoBidProfile
# Generate: openssl rand -hex 32
API_KEYS_ENCRYPTION_KEY=

# Local IMAP + job-analysis bridge (bid-assistant extension connects here)
BRIDGE_HOST=127.0.0.1
# Must not use 3847 — reserved for Avalon relay (socket.io)
BRIDGE_PORT=3848

# Default applier when the extension does not send applierName
APPLIER_NAME=

# Optional fallback model for OpenAI job analysis when profile has no default OpenAI model set
OPENAI_MODEL=gpt-4o-mini

# Force IPv4 when outbound IPv6 paths time out (some vendor networks)
# MONGO_IPV4_ONLY=1

# Optional: override the job-analysis prompt from a file. The prompt is embedded in
# the code (src/config/jobAnalysisPrompt.js) and used by default; set this only to
# load a custom prompt from disk instead.
# PROMPT_MD_PATH=
